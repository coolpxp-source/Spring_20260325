<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.UserMapper">
	<!-- 여러개 검색 -->
    <select id="selectUserList" parameterType="hashmap" resultType="com.example.demo.model.User">
   		SELECT *
   		FROM TBL_USER
    </select>

	<select id="selectUser" parameterType="hashmap" resultType="com.example.demo.model.User">
		SELECT *
		FROM TBL_USER
		WHERE USERID = #{userId}
	</select>
	<!--아이디 중복체크에서 selectUser 재사용했습니다.-->
	
	<insert id="insertUser" parameterType="hashmap">
		INSERT INTO TBL_USER(USERID, PWD, USERNAME) 
		VALUES(#{userId}, #{hashPwd}, #{userName})
	</insert>
	
	<!-- 삭제 -->
   <delete id="deleteUser" parameterType="hashmap">
    	DELETE FROM TBL_USER WHERE USERID = #{userId}
    </delete>
    
    <select id="selectUserProfile" parameterType="hashmap" resultType="com.example.demo.model.User">
        SELECT *
        FROM TBL_USER_FILE
        WHERE USERID = #{userId}
    </select> 
    
    <insert id="selectUserFile" parameterType="hashmap">
    	INSERT INTO TBL_USER_FILE
    	VALUES(null,#{idx},#{path}, #{fileName}, #{orgName},#{size},#{extName} )
    </insert>
</mapper>